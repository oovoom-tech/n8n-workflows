    {
      "id": "diff",
      "name": "Diff Engine",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        750,
        300
      ],
      "parameters": {
        "jsCode": "function slugify(name) {\n  return name.toLowerCase().normalize('NFD').replace(/[\\u0300-\\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').replace(/-{2,}/g, '-');\n}\n\n// Read manifest from GitHub (base64 encoded content)\nvar manifestNode = $('Get Manifest').first().json;\nvar manifest = {};\nif (manifestNode && manifestNode.content) {\n  try {\n    var decoded = Buffer.from(manifestNode.content, 'base64').toString('utf8');\n    manifest = JSON.parse(decoded);\n  } catch(e) { manifest = {}; }\n}\n\nvar workflows = $('List All Workflows').all().map(function(i) { return i.json; });\nvar actions = [];\nvar seenIds = {};\n\nfor (var i = 0; i < workflows.length; i++) {\n  var wf = workflows[i];\n  var id = wf.id;\n  seenIds[id] = true;\n  var filename = slugify(wf.name) + '_' + id.slice(0, 8) + '.json';\n  var prev = manifest[id];\n  if (!prev) {\n    actions.push({ action: 'create', id: id, name: wf.name, filename: filename });\n  } else if (prev.name !== wf.name) {\n    actions.push({ action: 'rename', id: id, name: wf.name, filename: filename, oldFilename: prev.filename });\n  } else if (prev.updatedAt !== wf.updatedAt) {\n    actions.push({ action: 'update', id: id, name: wf.name, filename: filename });\n  }\n}\n\nvar manifestIds = Object.keys(manifest);\nfor (var j = 0; j < manifestIds.length; j++) {\n  var mid = manifestIds[j];\n  if (!seenIds[mid]) {\n    actions.push({ action: 'delete', id: mid, name: manifest[mid].name, filename: manifest[mid].filename });\n  }\n}\n\n// Build new manifest for commit\nvar newManifest = {};\nfor (var k = 0; k < workflows.length; k++) {\n  var w = workflows[k];\n  var fn = slugify(w.name) + '_' + w.id.slice(0, 8) + '.json';\n  newManifest[w.id] = { filename: fn, name: w.name, updatedAt: w.updatedAt };\n}\n\n// Store newManifest for Prepare Git Data node\nvar staticData = $getWorkflowStaticData('global');\nstaticData.pendingManifest = newManifest;\nstaticData.oldManifest = manifest;\n\nif (actions.length === 0) return [];\nreturn actions.map(function(a) { return { json: a }; });"
      }
    },
