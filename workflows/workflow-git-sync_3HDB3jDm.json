      {
        "id": "prepare",
        "name": "Prepare Git Data",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1500,
          200
        ],
        "parameters": {
          "jsCode": "function cleanWorkflow(wf) {\n  var cleaned = JSON.parse(JSON.stringify(wf));\n  delete cleaned.createdAt;\n  delete cleaned.updatedAt;\n  delete cleaned.versionId;\n  delete cleaned.triggerCount;\n  delete cleaned.staticData;\n  if (cleaned.meta) delete cleaned.meta.instanceId;\n  return cleaned;\n}\n\nvar staticData = $getWorkflowStaticData('global');\nvar pendingManifest = staticData.pendingManifest || {};\nvar oldManifest = staticData.oldManifest || {};\nvar fetchedWorkflows = $input.all().map(function(i) { return i.json; });\nvar treeEntries = [];\nvar stats = { created: 0, updated: 0, renamed: 0, deleted: 0 };\nvar details = { created: [], updated: [], renamed: [], deleted: [] };\n\nfor (var k = 0; k < fetchedWorkflows.length; k++) {\n  var wf = fetchedWorkflows[k];\n  if (!wf.id || !wf.nodes) continue;\n  var entry = pendingManifest[wf.id];\n  if (!entry) continue;\n  var oldEntry = oldManifest[wf.id];\n  var cleaned = cleanWorkflow(wf);\n  var content = JSON.stringify(cleaned, null, 2);\n  treeEntries.push({ path: 'workflows/' + entry.filename, mode: '100644', type: 'blob', content: content });\n  if (!oldEntry) {\n    stats.created++;\n    details.created.push(wf.name);\n  } else if (oldEntry.name !== entry.name) {\n    treeEntries.push({ path: 'workflows/' + oldEntry.filename, mode: '100644', type: 'blob', sha: null });\n    stats.renamed++;\n    details.renamed.push(oldEntry.name + ' -> ' + wf.name);\n  } else {\n    stats.updated++;\n    details.updated.push(wf.name);\n  }\n}\n\nvar manifestIds = Object.keys(oldManifest);\nfor (var m = 0; m < manifestIds.length; m++) {\n  var did = manifestIds[m];\n  if (!pendingManifest[did]) {\n    treeEntries.push({ path: 'workflows/' + oldManifest[did].filename, mode: '100644', type: 'blob', sha: null });\n    stats.deleted++;\n    details.deleted.push(oldManifest[did].name);\n  }\n}\n\ntreeEntries.push({ path: 'manifest.json', mode: '100644', type: 'blob', content: JSON.stringify(pendingManifest, null, 2) });\n\nvar parts = [];\nif (stats.created > 0) parts.push('+' + stats.created + ' new');\nif (stats.updated > 0) parts.push('~' + stats.updated + ' updated');\nif (stats.renamed > 0) parts.push('>' + stats.renamed + ' renamed');\nif (stats.deleted > 0) parts.push('-' + stats.deleted + ' deleted');\nvar title = 'sync: ' + parts.join(', ');\n\nvar body = '';\nif (details.created.length > 0) body += '\\nCreated:\\n' + details.created.map(function(n) { return '  + ' + n; }).join('\\n');\nif (details.updated.length > 0) body += '\\nUpdated:\\n' + details.updated.map(function(n) { return '  ~ ' + n; }).join('\\n');\nif (details.renamed.length > 0) body += '\\nRenamed:\\n' + details.renamed.map(function(n) { return '  > ' + n; }).join('\\n');\nif (details.deleted.length > 0) body += '\\nDeleted:\\n' + details.deleted.map(function(n) { return '  - ' + n; }).join('\\n');\n\nreturn [{ json: { treeEntries: treeEntries, commitMessage: title + '\\n' + body, stats: stats } }];"
        }
      },
