      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst plaque = (input.body?.license_plate || input.license_plate || '').toUpperCase().replace(/[^A-Z0-9]/g, '');\nconst vehicle_id = input.body?.vehicle_id || input.vehicle_id;\nconst callback_url = input.body?.callback_url || input.callback_url;\nreturn [{ json: { plaque, vehicle_id, callback_url, s3_prefix: `plaques/${plaque}` } }];"
      },
