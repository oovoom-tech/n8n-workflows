      "parameters": {
        "jsCode": "const normalize = $('Normalize Plaque').first().json;\nconst item = $input.first().json;\nconst hasCache = !item.error;\nreturn [{ json: { ...normalize, hasCache, image_url: hasCache ? `https://fiche-auto-cache.s3.eu-west-3.amazonaws.com/${normalize.s3_prefix}/photo.webp` : null } }];"
