    {
      "parameters": {
        "jsCode": "const xml = $input.first().json.data;\nif (!xml) throw new Error('RegCheck: empty response');\nconst match = xml.match(/<vehicleJson>([\\s\\S]*?)<\\/vehicleJson>/);\nif (!match || !match[1]) throw new Error('RegCheck: vehicleJson not found');\nconst vehicle = JSON.parse(match[1]);\nconst ext = vehicle.ExtendedData || {};\nconst normalize = $('Normalize Plaque').first().json;\nreturn [{ json: {\n  ...normalize,\n  marque: vehicle.CarMake?.CurrentTextValue || ext.marque || '',\n  modele: vehicle.CarModel?.CurrentTextValue || ext.modele || '',\n  annee: vehicle.RegistrationYear || ext.anneeSortie || '',\n  couleur: ext.couleur || ''\n}}];"
      },
      "id": "parse-regcheck-1",
      "name": "Parse RegCheck",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1568,
        56
      ]
    },
    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nconst color = d.couleur || 'orange';\n\nconst prompt = [\n  `${d.annee} ${d.marque} ${d.modele} in ${color}`,\n  '3/4 front view',\n  'professional automotive studio photography',\n  'pure white seamless background',\n  'soft natural lighting',\n  'blank white license plate with no text, no numbers, no characters',\n  'photorealistic, high detail, 8k'\n].join(', ');\n\nreturn [{ json: { ...d, image_prompt: prompt } }];"
      },
      "id": "build-prompt-1",
      "name": "Build Image Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1792,
        56
      ]
    },
    {
      "parameters": {
        "jsCode": "const inputItem = $input.first();\nconst normalize = $('Normalize Plaque').first().json;\nreturn [{ json: { s3_prefix: normalize.s3_prefix }, binary: inputItem.binary }];"
      },
