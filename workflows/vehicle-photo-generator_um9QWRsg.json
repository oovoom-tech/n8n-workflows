    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst b64 = response.data[0].b64_json;\nconst normalize = $('Normalize Plaque').first().json;\nconst buffer = Buffer.from(b64, 'base64');\nreturn [{\n  json: { s3_prefix: normalize.s3_prefix, vehicle_id: normalize.vehicle_id, callback_url: normalize.callback_url },\n  binary: { data: await this.helpers.prepareBinaryData(buffer, 'photo.webp', 'image/webp') }\n}];"
      },
